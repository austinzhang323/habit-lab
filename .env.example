# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Prisma Postgres Accelerate connection string (runtime)
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# Prisma Postgres direct connection (migrations + NextAuth adapter via prisma-auth)
# Use sslmode=verify-full (pg v8+; avoid sslmode=require — deprecated alias warning)
DIRECT_DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=verify-full"

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# Google OAuth (Web application client; redirect: {NEXTAUTH_URL}/api/auth/callback/google)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
